rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Jobs — public read, admin write
    match /jobs/{jobId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Candidates — public create (anyone can apply), admin read/write
    match /candidates/{candidateId} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }

    // Availability — public read (for scheduling), admin write
    match /availability/{slotId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Users — authenticated read; write own doc or admin write any
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update, delete: if request.auth != null;
    }

    // Interview questions — public read (for candidate apply flow), admin write
    match /interviewQuestions/{questionId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Verification codes — server-side only (Cloud Functions use Admin SDK)
    match /verificationCodes/{codeId} {
      allow read, write: if false;
    }

    // System — public read (force-refresh signal broadcast to all clients),
    // authenticated (admin) write.
    match /system/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Everything else — admin only
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
