rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userPath() {
      return /databases/$(database)/documents/users/$(request.auth.uid);
    }

    function hasUserProfile() {
      return signedIn() && exists(userPath());
    }

    function userProfile() {
      return get(userPath()).data;
    }

    function isEnabledAdmin() {
      return hasUserProfile()
        && userProfile().disabled != true
        && userProfile().role in ['superadmin', 'manager'];
    }

    function isSuperadmin() {
      return isEnabledAdmin() && userProfile().role == 'superadmin';
    }

    function hasPermission(permission) {
      return isSuperadmin()
        || (isEnabledAdmin()
          && userProfile().permissions is list
          && permission in userProfile().permissions);
    }

    function isString(value, maxLength) {
      return value is string && value.size() > 0 && value.size() <= maxLength;
    }

    function optionalString(value, maxLength) {
      return value == null || (value is string && value.size() <= maxLength);
    }

    function validAcknowledgements(value) {
      return value is map
        && value.keys().hasOnly([
          'processNoticeAccepted', 'aiReviewAccepted', 'accuracyCertified', 'acceptedAt'
        ])
        && value.processNoticeAccepted == true
        && value.aiReviewAccepted == true
        && value.accuracyCertified == true
        && value.acceptedAt == request.time;
    }

    function validCheckedAcknowledgementIds(value) {
      return value is list
        && value.size() == 3
        && 'processNoticeAccepted' in value
        && 'aiReviewAccepted' in value
        && 'accuracyCertified' in value;
    }

    function validEeoSurvey(value) {
      return value is map
        && value.keys().hasOnly([
          'optedIn', 'status', 'gender', 'raceEthnicity'
        ])
        && value.optedIn is bool
        && value.status in ['provided', 'not_provided']
        && value.gender in [
          'Prefer not to answer', 'Woman', 'Man', 'Non-binary', 'Self-describe'
        ]
        && value.raceEthnicity in [
          'Prefer not to answer', 'Hispanic or Latino',
          'American Indian or Alaska Native', 'Asian',
          'Black or African American', 'Native Hawaiian or Other Pacific Islander',
          'White', 'Two or more races', 'Self-describe'
        ]
        && value.optedIn == true
        && value.status == 'provided';
    }

    function validCandidateResume(data) {
      return (
          data.resumeSkipped == true
          && data.resumeUrl == null
        ) || (
          (data.resumeSkipped == false || data.resumeSkipped == null)
          && isString(data.resumeUrl, 260)
          && data.resumeUrl.matches('^resumes/' + data.candidateId + '/[^/]+$')
        );
    }

    function validCandidateCreate(candidateId) {
      let data = request.resource.data;
      return data.keys().hasOnly([
          'candidateId', 'firstName', 'lastName', 'email', 'phone',
          'jobId', 'jobTitle', 'roleKey', 'dealership', 'clientName',
          'organizationName', 'location', 'stage', 'resumeUrl', 'resumeSkipped',
          'videoResponses', 'textResponses', 'questions',
          'timingData', 'statusToken', 'compositeScore', 'resumeScore',
          'interviewScore', 'selectionProcessVersion', 'complianceNoticeVersion',
          'complianceAcknowledgedAt', 'createdAt', 'updatedAt'
        ])
        && data.candidateId == candidateId
        && isString(data.candidateId, 80)
        && isString(data.firstName, 80)
        && isString(data.lastName, 80)
        && isString(data.email, 160)
        && isString(data.phone, 40)
        && isString(data.jobId, 120)
        && isString(data.jobTitle, 160)
        && isString(data.roleKey, 80)
        && optionalString(data.dealership, 120)
        && optionalString(data.clientName, 160)
        && optionalString(data.organizationName, 160)
        && optionalString(data.location, 160)
        && data.stage == 'applied'
        && validCandidateResume(data)
        && isString(data.selectionProcessVersion, 40)
        && isString(data.complianceNoticeVersion, 40)
        && data.complianceAcknowledgedAt == request.time
        && data.videoResponses is map
        && data.textResponses is map
        && data.questions is map
        && data.timingData is map
        && isString(data.statusToken, 100)
        && data.compositeScore == null
        && data.resumeScore == null
        && data.interviewScore == null
        && data.createdAt == request.time
        && data.updatedAt == request.time;
    }

    function validCandidateComplianceCreate(candidateId) {
      let data = request.resource.data;
      return data.keys().hasOnly([
          'candidateId', 'jobId', 'jobTitle', 'roleKey',
          'selectionProcessVersion', 'complianceNoticeVersion',
          'eeoSurveyVersion', 'employerDisplayName', 'parentOrgDisplayName',
          'renderedTextHash', 'renderedNoticeText', 'checkedAcknowledgementIds',
          'userAgent', 'acknowledgements', 'createdAt'
        ])
        && data.candidateId == candidateId
        && isString(data.candidateId, 80)
        && isString(data.jobId, 120)
        && isString(data.jobTitle, 160)
        && isString(data.roleKey, 80)
        && isString(data.selectionProcessVersion, 40)
        && isString(data.complianceNoticeVersion, 40)
        && isString(data.eeoSurveyVersion, 40)
        && isString(data.employerDisplayName, 160)
        && isString(data.parentOrgDisplayName, 160)
        && isString(data.renderedTextHash, 128)
        && isString(data.renderedNoticeText, 8000)
        && validCheckedAcknowledgementIds(data.checkedAcknowledgementIds)
        && isString(data.userAgent, 600)
        && validAcknowledgements(data.acknowledgements)
        && existsAfter(/databases/$(database)/documents/candidates/$(candidateId))
        && data.createdAt == request.time;
    }

    function validEeoResponseCreate(candidateId) {
      let data = request.resource.data;
      return data.keys().hasOnly([
          'candidateId', 'jobId', 'jobTitle', 'roleKey',
          'employerDisplayName', 'parentOrgDisplayName',
          'eeoSurveyVersion', 'eeoSurvey', 'createdAt'
        ])
        && data.candidateId == candidateId
        && isString(data.candidateId, 80)
        && isString(data.jobId, 120)
        && isString(data.jobTitle, 160)
        && isString(data.roleKey, 80)
        && isString(data.employerDisplayName, 160)
        && isString(data.parentOrgDisplayName, 160)
        && isString(data.eeoSurveyVersion, 40)
        && validEeoSurvey(data.eeoSurvey)
        && existsAfter(/databases/$(database)/documents/candidates/$(candidateId))
        && existsAfter(/databases/$(database)/documents/candidateCompliance/$(candidateId))
        && data.createdAt == request.time;
    }

    match /jobs/{jobId} {
      allow get, list: if isSuperadmin()
        || resource.data.status == 'active';
      allow create, update, delete: if hasPermission('manage_jobs');
    }

    match /candidates/{candidateId} {
      allow create: if validCandidateCreate(candidateId);
      allow get, list: if hasPermission('view_candidates');
      allow update: if hasPermission('score_candidates') || hasPermission('schedule_interviews');
      allow delete: if isSuperadmin();
    }

    match /candidateCompliance/{candidateId} {
      allow create: if validCandidateComplianceCreate(candidateId);
      allow get, list: if hasPermission('view_analytics');
      allow update, delete: if false;
    }

    match /eeoResponses/{candidateId} {
      allow create: if validEeoResponseCreate(candidateId);
      allow get, list: if hasPermission('view_analytics');
      allow update, delete: if false;
    }

    match /onboardings/{candidateId} {
      allow get, list: if hasPermission('view_candidates') || hasPermission('manage_onboarding');
      allow create, update: if hasPermission('manage_onboarding');
      allow delete: if isSuperadmin();
    }

    match /availability/{slotId} {
      allow get, list, create, update, delete: if hasPermission('manage_availability');
    }

    match /users/{userId} {
      allow get: if (signedIn() && request.auth.uid == userId) || isSuperadmin();
      allow list: if isSuperadmin();
      allow create, update, delete: if false;
    }

    match /interviewQuestions/{questionId} {
      allow get, list: if isSuperadmin() || resource.data.active == true;
      allow create, update, delete: if hasPermission('manage_questions');
    }

    match /roleRubrics/{roleKey} {
      allow get, list: if isEnabledAdmin();
      allow create, update, delete: if hasPermission('manage_questions');
    }

    match /verificationCodes/{codeId} {
      allow read, write: if false;
    }

    match /system/{docId} {
      allow get, list: if true;
      allow create, update, delete: if isSuperadmin();
    }

    match /auditLogs/{logId} {
      allow get, list: if isSuperadmin();
      allow create, update, delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
