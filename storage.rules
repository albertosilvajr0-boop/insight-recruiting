rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Resumes — anyone can upload (candidates applying), admin can read
    match /resumes/{candidateId}/{fileName} {
      allow read: if request.auth != null;
      allow create: if true;
    }

    // Videos — anyone can upload chunks, admin can read
    match /videos/{candidateId}/{fileName} {
      allow read: if request.auth != null;
      allow create: if true;
    }

    // Everything else — admin only
    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}
