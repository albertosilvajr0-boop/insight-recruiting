rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Resumes — anyone can upload, admin can read
    match /resumes/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if true;
    }

    // Videos — anyone can upload, admin can read
    match /videos/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if true;
    }

    // Everything else — admin only
    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}
