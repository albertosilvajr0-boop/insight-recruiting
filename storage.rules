rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function userPath() {
      return /databases/(default)/documents/users/$(request.auth.uid);
    }

    function hasUserProfile() {
      return signedIn() && firestore.exists(userPath());
    }

    function userProfile() {
      return firestore.get(userPath()).data;
    }

    function isEnabledAdmin() {
      return hasUserProfile()
        && userProfile().disabled != true
        && userProfile().role in ['superadmin', 'manager'];
    }

    function isSuperadmin() {
      return isEnabledAdmin() && userProfile().role == 'superadmin';
    }

    function hasPermission(permission) {
      return isSuperadmin()
        || (isEnabledAdmin()
          && userProfile().permissions is list
          && permission in userProfile().permissions);
    }

    function validCandidateKey(candidateId) {
      return candidateId.matches('^[A-Za-z0-9_-]{8,80}$');
    }

    function validVideoKey(videoKey) {
      return videoKey.matches('^[A-Za-z0-9_-]{8,80}(_q[0-9]{1,3})?$');
    }

    match /resumes/{candidateId}/{fileName} {
      allow read: if hasPermission('view_candidates');
      allow create: if validCandidateKey(candidateId)
        && request.resource.size <= 10 * 1024 * 1024
        && request.resource.contentType in [
          'application/pdf',
          'application/msword',
          'application/vnd.openxmlformats-officedocument.wordprocessingml.document'
        ];
      allow update, delete: if false;
    }

    match /videos/{videoKey}/{fileName} {
      allow read: if hasPermission('view_candidates');
      allow create: if validVideoKey(videoKey)
        && request.resource.size <= 250 * 1024 * 1024
        && request.resource.contentType in ['video/webm', 'video/mp4']
        && fileName.matches('^(recording|full_recording|chunk_[0-9]{4})\\.(webm|mp4)$');
      allow update, delete: if false;
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
