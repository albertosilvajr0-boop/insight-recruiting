{
  "name": "insight-recruiting",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "lint": "eslint .",
    "test": "vitest run",
    "check": "npm run lint && npm run test && npm run build",
    "audit:high": "npm audit --audit-level=high && npm --prefix functions audit --audit-level=high",
    "audit:all": "npm audit --audit-level=moderate && npm --prefix functions audit --audit-level=moderate",
    "build": "vite build",
    "preview": "vite preview",
    "deploy": "npm run check && npx firebase-tools deploy"
  },
  "dependencies": {
    "date-fns": "^3.6.0",
    "firebase": "^12.12.1",
    "jszip": "^3.10.1",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-router-dom": "^6.23.0",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "postcss": "^8.5.12",
    "tailwindcss": "^3.4.4",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  }
}
