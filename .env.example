# Copy this to .env and fill in your values
# Never commit .env to git

# Firebase (frontend)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Firebase Functions (set via: firebase functions:secrets:set ANTHROPIC_API_KEY)
ANTHROPIC_API_KEY=

# Google APIs (service account with Calendar + Gmail scope)
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json
GMAIL_SENDER=albertosilva@silvaconsultinggroup.com
GOOGLE_CALENDAR_ID=primary

# App
VITE_APP_URL=https://your-project.web.app
VITE_RECRUITING_COMPLIANCE_EMAIL=albertosilva@silvaconsultinggroup.com
